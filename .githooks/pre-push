remote_name="$1"

if [ "${LIBRE_CLAW_SKIP_GITLAB_MIRROR:-}" = "1" ]; then
    exit 0
fi

if [ "$remote_name" != "origin" ]; then
    exit 0
fi

current_branch="$(git branch --show-current 2>/dev/null)"
if [ "$current_branch" != "main" ]; then
    exit 0
fi

if ! git config --get remote.gitlab.url >/dev/null; then
    exit 0
fi

printf '%s\n' "Mirroring main to GitLab squashed-main..."
LIBRE_CLAW_SKIP_GITLAB_MIRROR=1 git push gitlab HEAD:refs/heads/squashed-main
